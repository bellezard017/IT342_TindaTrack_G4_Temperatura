<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TindaTrackMobile"
        android:usesCleartextTraffic="true">

        <!-- LAUNCHER: Login screen -->
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.TindaTrackMobile.Auth"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Register chooser (coral) -->
        <activity
            android:name=".RegisterActivity"
            android:theme="@style/Theme.TindaTrackMobile.Auth"
            android:windowSoftInputMode="adjustResize" />

        <!-- Owner register form (white) -->
        <activity
            android:name=".OwnerRegisterActivity"
            android:theme="@style/Theme.TindaTrackMobile.White"
            android:windowSoftInputMode="adjustResize" />

        <!-- Staff register form (white) -->
        <activity
            android:name=".StaffRegisterActivity"
            android:theme="@style/Theme.TindaTrackMobile.White"
            android:windowSoftInputMode="adjustResize" />

        <!-- Main dashboard (cream bg) -->
        <activity
            android:name=".MainActivity"
            android:theme="@style/Theme.TindaTrackMobile.Main" />

    </application>

</manifest>
